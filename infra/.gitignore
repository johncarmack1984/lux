# Local provider plugins (the committed .terraform.lock.hcl is kept)
.terraform/
# Variable files hold secrets (e.g. discord_public_key)
*.tfvars
*.auto.tfvars
# Remote state is in S3; ignore any local state that shows up
*.tfstate
*.tfstate.*
# Saved plans (ephemeral)
tfplan
*.tfplan
# Placeholder Lambda zip generated by the archive provider (accounts.tf)
.sync-api-placeholder.zip
# Discord registration secrets (bot token + application id)
discord.env

# AWS IoT Core — remote control (the lux-discord-bot Lambda publishes here).
# Endpoint + device cert/key come from `terraform -chdir=infra output`;
# AmazonRootCA1.pem is Amazon's public root CA. Leave unset to run the app
# without remote control.
AWS_IOT_ENDPOINT=
AWS_IOT_CERT_PATH=./certs/device.pem.crt
AWS_IOT_KEY_PATH=./certs/device.private.key
AWS_IOT_ROOT_CA_PATH=./certs/AmazonRootCA1.pem
LUX_DEVICE_ID=lux-1

# Accounts + cloud sync (Cognito + DynamoDB). Values come from
# `terraform -chdir=infra output`. Read by the app-side account client (Phase 2);
# leave unset to run the app local-only, with no sign-in or sync.
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_REGION=
LUX_SYNC_URL=
